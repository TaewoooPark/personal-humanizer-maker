#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""style_metrics.py — {{DISPLAY}} 자가검증기 (auto-generated by personal-humanizer-maker).

이 파일은 방출된 스킬 전용 — 저자의 기준선 밴드가 baked-in 되어 있다. 문체의 '형태'만
측정하며 내용·사실은 평가하지 않는다. WARN은 검토 신호일 뿐 실패가 아니다: 의미 불변
철칙(SKILL.md §0)을 어기면서까지 수치를 맞추지 말 것.

    python3 style_metrics.py <file.md>
    cat 다듬은본문 | python3 style_metrics.py -
"""
import sys
import os

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _profile_core import measure  # vendored copy of the profiler's measurement core

LANG = "__LANG__"

# baseline bands, derived from the author's own corpus by the maker.
# each entry: {"min": x} floor / {"max": y} ceiling / {"min": x, "max": y} band.
# "strict": False means WARN-only (advisory axis / thin corpus) — never a hard fail.
BASELINE = __BASELINE__


def dig(d, path):
    cur = d
    for k in path.split("."):
        if not isinstance(cur, dict) or k not in cur:
            return None
        cur = cur[k]
    return cur


def check(value, band):
    if value is None:
        return None
    lo, hi = band.get("min"), band.get("max")
    ok = True
    if lo is not None and value < lo:
        ok = False
    if hi is not None and value > hi:
        ok = False
    return ok


def fmt_band(band):
    lo, hi = band.get("min"), band.get("max")
    if lo is not None and hi is not None:
        return f"[{lo}, {hi}]"
    if lo is not None:
        return f">= {lo}"
    if hi is not None:
        return f"<= {hi}"
    return "?"


def main():
    if len(sys.argv) > 1 and sys.argv[1] != "-":
        raw = open(sys.argv[1], encoding="utf-8").read()
    else:
        raw = sys.stdin.read()

    prof = measure(raw, LANG)
    m = prof["metrics"]
    print(f"# {{DISPLAY}} — style check  (lang={LANG}, sents={prof['corpus']['n_sentences']}"
          f"{', THIN' if prof['corpus']['thin'] else ''})")

    hard_fail = 0
    warns = 0
    for path, band in BASELINE.items():
        v = dig(m, path)
        ok = check(v, band)
        strict = band.get("strict", True)
        if ok is None:
            tag = "n/a "
        elif ok:
            tag = "PASS"
        elif strict:
            tag = "FAIL"
            hard_fail += 1
        else:
            tag = "WARN"
            warns += 1
        vs = "—" if v is None else (round(v, 2) if isinstance(v, float) else v)
        note = "" if strict else "  (advisory)"
        print(f"  [{tag}] {path}: {vs}  target {fmt_band(band)}{note}")

    print(f"\n  summary: {hard_fail} FAIL, {warns} WARN")
    print("  주의: WARN은 검토 신호일 뿐 실패가 아니다. 의미 불변(§0)이 언제나 수치보다 우선한다.")
    return 1 if hard_fail else 0


if __name__ == "__main__":
    sys.exit(main())
